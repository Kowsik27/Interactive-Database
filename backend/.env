# ============================================================
#  DB Chat Assistant — Environment Configuration Template
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# IBM watsonx.ai — Granite LLM
# ------------------------------------------------------------
# Obtain from: https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=zYyIpDDLXdn8Wqlbim7-gPcLijzPDZJeIL2rkGAA_pxr
# Obtain from your watsonx.ai project settings
WATSONX_PROJECT_ID=dd86be3f-d730-4759-b7bd-4e8f6c22ae51

# Regional endpoint — change only if using a different region
WATSONX_URL=https://us-south.ml.cloud.ibm.com
# Model to use for SQL generation and summarisation
GRANITE_MODEL_ID=ibm/granite-3-8b-instruct

# ------------------------------------------------------------
# Application Server
# ------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000

# Set to true only during local development
DEBUG=false

# ------------------------------------------------------------
# Query Safety & Performance
# ------------------------------------------------------------
# Maximum rows a single SELECT may return (prevents runaway queries)
MAX_ROWS_RETURNED=500

# Number of previous conversation turns injected into every prompt
CHAT_HISTORY_WINDOW=10

# Hard timeout (seconds) for any single SQL query execution
MAX_EXECUTION_TIME_SECONDS=30

# Comma-separated list of additionally blocked SQL keywords (optional)
# Example: EXTRA_BLOCKED_KEYWORDS=LOAD,OUTFILE
EXTRA_BLOCKED_KEYWORDS=
