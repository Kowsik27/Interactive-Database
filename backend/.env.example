# ============================================================
#  DBChat AI — Environment Configuration Template
#  1. Copy this file:  cp .env.example .env
#  2. Fill in your real values in .env
#  3. NEVER commit .env to version control
# ============================================================

# ------------------------------------------------------------
# IBM watsonx.ai — Granite LLM
# ------------------------------------------------------------
# Get your API key from: https://cloud.ibm.com/iam/apikeys
# Click "Create an IBM Cloud API key" — copy the 44-char value
WATSONX_API_KEY=your_ibm_cloud_api_key_here

# Get from: https://dataplatform.cloud.ibm.com
# Open your project → Manage tab → copy the Project ID (UUID)
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# Regional endpoint — must match the region your project is in
# US South (Dallas):   https://us-south.ml.cloud.ibm.com
# Europe (Frankfurt):  https://eu-de.ml.cloud.ibm.com
# Europe (London):     https://eu-gb.ml.cloud.ibm.com
# Japan (Tokyo):       https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Model ID — granite-3-8b-instruct works across all regions
# Alternatives: ibm/granite-3-2b-instruct, ibm/granite-13b-chat-v2
GRANITE_MODEL_ID=ibm/granite-3-8b-instruct

# ------------------------------------------------------------
# Application Server
# ------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# ------------------------------------------------------------
# Query Safety & Performance
# ------------------------------------------------------------
# Maximum rows a single SELECT may return (prevents runaway queries)
MAX_ROWS_RETURNED=500

# Number of previous conversation turns injected into every LLM prompt
CHAT_HISTORY_WINDOW=10

# Hard timeout (seconds) for any single SQL query execution
MAX_EXECUTION_TIME_SECONDS=30

# Extra SQL keywords to block (comma-separated, optional)
EXTRA_BLOCKED_KEYWORDS=
